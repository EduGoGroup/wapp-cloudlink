# .env.example — wapp-cloudlink (dev, servidor standalone / democloud)
#
# Plantilla versionada (patrón EduGo). Copia a `.env`; `.env` está en .gitignore.
# Cárgalo en la shell antes de arrancar:
#     set -a; . ./.env; set +a
#     go run ./cmd/cloudlink        # o ./cmd/democloud
#
# ─── Puerto: BANDA wApp 81xx (aparte de EduGo 80xx) ───────────────────────────
# Ver docs/CONVENCIONES.md → "Rango de puertos por ecosistema".
#   8101  gRPC CloudLink (mismo puerto que WAPP_GRPC_CONNECT_ADDR de la plataforma)
CLOUDLINK_ADDR=:8101

# Directorio de certs mTLS de dev (genera con scripts/gen-dev-certs.sh).
CLOUDLINK_CERT_DIR=certs
